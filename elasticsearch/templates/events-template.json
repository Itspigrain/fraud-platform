{
  "index_patterns": ["events-*"],
  "template": {
    "aliases": {
      "events": {}
    },
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "id":           { "type": "keyword" },
        "tenantId":     { "type": "keyword" },
        "eventType":    { "type": "keyword" },
        "eventTime":    { "type": "date" },
        "attributes":   { "type": "object", "dynamic": true }
      }
    }
  }
}
